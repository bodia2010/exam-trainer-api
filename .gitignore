.vercel
__pycache__/
.codegraph/
.env
.env.*
promptfoo/.env

# Fixtures are extracted from copyrighted exam-prep PDFs — regenerate
# locally with promptfoo/make_fixtures.py, never commit them.
promptfoo/fixtures/*
!promptfoo/fixtures/.gitkeep

# promptfoo's own local eval history/cache, plus any eval output we
# saved to disk — both can contain excerpts of the exam PDF content
promptfoo/.promptfoo/
promptfoo/results_*.json

# Same policy — these embed verbatim source snippets from the specific
# document they were written against (see the 2026-07-12 commit that
# introduced check_answer_keys.py/verify_content.py for the reasoning).
scripts/fix_course.py
.idea/
